{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumaForge Lite",
  "version": "0.1.0",
  "identifier": "com.einey.luma-lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LumaForge Lite",
        "width": 620,
        "height": 580,
        "minWidth": 380,
        "minHeight": 400,
        "visible": true,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
